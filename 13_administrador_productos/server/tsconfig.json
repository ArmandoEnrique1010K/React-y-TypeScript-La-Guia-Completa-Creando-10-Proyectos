{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        // "lib": ["esnext"],
        "lib": ["ES2020"],
        "types": ["node"],
        "target": "ESNext",
        "moduleResolution": "NodeNext",
        "module": "NodeNext",
        "strict": false,
        "sourceMap": true,
        "esModuleInterop": true,
        "declaration": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        // Pruebas
        "isolatedModules": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts"]
}
